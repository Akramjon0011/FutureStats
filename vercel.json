{
  "name": "futurestats-app",
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/trigger-scheduler",
      "schedule": "0 0 * * *"
    }
  ]
}
